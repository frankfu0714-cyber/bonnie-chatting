        "zh-Hant" : {
          "stringUnit" : { "state" : "translated", "value" : "不行,再等等" }
        }
      }
    },
    "jiaobei.outcome.yin.desc" : {
      "localizations" : {
        "en" : {
          "stringUnit" : { "state" : "translated", "value" : "Both curved sides land up. The deity does not agree — wait, reconsider, or choose another path." }
        },
        "zh-Hant" : {
          "stringUnit" : { "state" : "translated", "value" : "兩面皆凸 — 神明不允,先緩一緩,或另尋他法。" }
        }
      }
