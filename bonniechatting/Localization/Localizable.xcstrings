    "jiaobei.outcome.sheng.title" : {
      "localizations" : {
        "en" : {
          "stringUnit" : { "state" : "translated", "value" : "Sacred Yes" }
        },
        "zh-Hant" : {
          "stringUnit" : { "state" : "translated", "value" : "神明應允" }
        }
      }
    },
    "jiaobei.outcome.sheng.default_label" : {
      "localizations" : {
        "en" : {
          "stringUnit" : { "state" : "translated", "value" : "Yes — go ahead" }
        },
        "zh-Hant" : {
          "stringUnit" : { "state" : "translated", "value" : "好，去做" }
        }
      }
    },
    "jiaobei.outcome.sheng.desc" : {
      "localizations" : {
        "en" : {
          "stringUnit" : { "state" : "translated", "value" : "One flat side and one curved side land up. The deity is in agreement — the answer is yes." }
        },
        "zh-Hant" : {
          "stringUnit" : { "state" : "translated", "value" : "一平一凸 — 神明同意,可以放心去做。" }
        }
      }
    },

    "jiaobei.outcome.xiao.name" : {
      "localizations" : {
        "en" : {
          "stringUnit" : { "state" : "translated", "value" : "笑筊" }
        },
        "zh-Hant" : {
          "stringUnit" : { "state" : "translated", "value" : "笑筊" }
