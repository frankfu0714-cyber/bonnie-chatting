      }
    },
    "jiaobei.outcome.xiao.title" : {
      "localizations" : {
        "en" : {
          "stringUnit" : { "state" : "translated", "value" : "Laughing Blocks" }
        },
        "zh-Hant" : {
          "stringUnit" : { "state" : "translated", "value" : "神明在笑" }
        }
      }
    },
    "jiaobei.outcome.xiao.default_label" : {
      "localizations" : {
        "en" : {
          "stringUnit" : { "state" : "translated", "value" : "The deity is laughing — try asking differently" }
        },
        "zh-Hant" : {
          "stringUnit" : { "state" : "translated", "value" : "神明在笑,再問一次" }
        }
      }
    },
    "jiaobei.outcome.xiao.desc" : {
      "localizations" : {
        "en" : {
          "stringUnit" : { "state" : "translated", "value" : "Both flat sides land up. Your question may be unclear, already answered, or not the right one. Rephrase and ask again." }
        },
        "zh-Hant" : {
          "stringUnit" : { "state" : "translated", "value" : "兩面皆平 — 問題不清或答案明顯,換個問法再問一次。" }
        }
      }
    },

    "jiaobei.outcome.yin.name" : {
      "localizations" : {
        "en" : {
          "stringUnit" : { "state" : "translated", "value" : "陰筊" }
